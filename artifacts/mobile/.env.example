# Expo loads this file from the MOBILE app directory (artifacts/mobile), NOT the
# monorepo root. Copy it to `artifacts/mobile/.env` and fill in real values:
#
#   cp artifacts/mobile/.env.example artifacts/mobile/.env
#
# Only EXPO_PUBLIC_* vars are exposed to the client bundle. After editing, restart
# the dev server with a clean cache:
#
#   pnpm --filter @workspace/mobile exec expo start -c

# Supabase — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key-here

# Mapbox — account.mapbox.com (public token, starts with pk.)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token-here
